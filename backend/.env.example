# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/workout_planner

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=1d

# Frontend URL used in password reset emails (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Resend (https://resend.com) — password reset emails
# Leave unset locally to log reset links to the server console instead.
RESEND_API_KEY=
# Must be a verified sender in Resend (default is Resend's sandbox sender)
MAIL_FROM=Workout Planner <onboarding@resend.dev>
